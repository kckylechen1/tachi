{
  "id": "memory-hybrid-bridge",
  "name": "Memory Hybrid Bridge",
  "description": "Advanced structured memory with LLM extraction and hybrid retrieval",
  "kind": "memory",
  "entry": "./index.js",
  "configSchema": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "shadowStorePath": {
        "type": "string"
      },
      "auditLogPath": {
        "type": "string"
      },
      "promptPath": {
        "type": "string"
      },
      "topK": {
        "type": "integer",
        "minimum": 1,
        "maximum": 20
      },
      "dedupThreshold": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "searchReadLimit": {
        "type": "integer",
        "minimum": 100,
        "maximum": 100000
      },
      "captureMinChars": {
        "type": "integer",
        "minimum": 1,
        "maximum": 10000
      },
      "captureTriggerKeywords": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  }
}
