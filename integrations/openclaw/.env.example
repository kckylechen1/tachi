# ─── OpenClaw Tachi Plugin ──────────────────────────────
# Copy this file to .env in the project root directory.
#
# The plugin loads environment variables from .env at startup.
# Most LLM/embedding operations are now handled server-side by Tachi.

# ─── Voyage AI Embedding (used by Tachi server) ───────
# Set this in Tachi's own env, not here (see Tachi README).
# VOYAGE_API_KEY=your_voyage_api_key_here

# ─── Storage ──────────────────────────────────────────
# MEMORY_DB_PATH=~/.tachi/memory.db

# ─── Optional Tuning ─────────────────────────────────
# MEMORY_BRIDGE_DEDUP_THRESHOLD=0.95
# MEMORY_BRIDGE_MERGE_THRESHOLD=0.85
