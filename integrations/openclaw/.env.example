# ─── OpenClaw Memory Hybrid Bridge Plugin ─────────────
# Copy this file to ~/.secrets/master.env (or set vars via direnv/.envrc)
#
# The plugin loads env from these files in order:
#   1. ~/.secrets/master.env     (base secrets, backfill only)
#   2. ~/.tachi/config.env       (overrides)
# Vars already in process.env (e.g. via direnv) take priority over (1).

# ─── Embedding & Reranking (Voyage AI) ────────────────
# Required for vector embedding and reranking
VOYAGE_API_KEY=your_voyage_api_key_here

# ─── LLM Extraction (SiliconFlow / OpenAI-compatible) ─
# Required for memory extraction from conversations
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
# MEMORY_BRIDGE_OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# MEMORY_BRIDGE_OPENAI_MODEL=THUDM/GLM-4-9B-0414

# ─── Storage ──────────────────────────────────────────
# MEMORY_DB_PATH=~/.tachi/memory.db

# ─── Optional Tuning ─────────────────────────────────
# MEMORY_BRIDGE_DEDUP_THRESHOLD=0.95
# MEMORY_BRIDGE_MERGE_THRESHOLD=0.85
# MEMORY_BRIDGE_EMBEDDING_MODEL=voyage-4
# MEMORY_BRIDGE_EMBEDDING_DIMENSION=1024
# OPENCLAW_MEMORY_BACKEND=mcp   # or "napi"
