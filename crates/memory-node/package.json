{
  "name": "@chaoxlabs/tachi-node",
  "version": "0.12.3",
  "description": "High-performance memory storage & hybrid search engine (Rust native module)",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.js"
    }
  },
  "napi": {
    "name": "tachi",
    "triples": {
      "defaults": true
    }
  },
  "scripts": {
    "build": "napi build --platform --release --cargo-cwd .",
    "build:debug": "napi build --platform --cargo-cwd .",
    "artifacts": "napi artifacts",
    "prepublishOnly": "napi prepublish -t npm"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2"
  },
  "license": "MIT",
  "repository": "https://github.com/kckylechen1/tachi",
  "homepage": "https://github.com/kckylechen1/tachi",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts",
    "*.node"
  ],
  "optionalDependencies": {
    "@chaoxlabs/tachi-node-win32-x64-msvc": "0.12.3",
    "@chaoxlabs/tachi-node-darwin-x64": "0.12.3",
    "@chaoxlabs/tachi-node-darwin-arm64": "0.12.3",
    "@chaoxlabs/tachi-node-linux-x64-gnu": "0.12.3",
    "@chaoxlabs/tachi-node-linux-arm64-gnu": "0.12.3"
  }
}
