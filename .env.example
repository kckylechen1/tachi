# ─── Embedding & Reranking ─────────────────────────────
# Voyage remains the recommended provider for vector embedding + rerank.
VOYAGE_API_KEY=your_voyage_api_key_here

# ─── Shared OpenAI-Compatible Defaults ─────────────────
# Backward-compatible fallback for all text lanes.
# The current Rust release talks OpenAI-compatible chat completions directly.
SILICONFLOW_API_KEY=your_default_chat_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1/chat/completions
SILICONFLOW_MODEL=Qwen/Qwen3.5-27B

# ─── Lane: Extraction ──────────────────────────────────
# Best for high-recall structured JSON extraction.
EXTRACT_API_KEY=
EXTRACT_BASE_URL=
EXTRACT_MODEL=Qwen/Qwen3.5-27B

# ─── Lane: Distillation / Compaction ───────────────────
# Best for compact rollups and section summaries.
# Benchmark winner: MiniMax 2.7, if exposed through a compatible gateway.
DISTILL_API_KEY=
DISTILL_BASE_URL=
# Example: MiniMax-M2.7
DISTILL_MODEL=

# ─── Lane: Reasoning / Evolution ───────────────────────
# Best for skill evolution, agent evolution, and harder planning.
# Benchmark winner: GLM-5.1 via a Z.AI/OpenAI-compatible endpoint.
REASONING_API_KEY=
REASONING_BASE_URL=
# Example: glm-5.1
REASONING_MODEL=

# ─── Lane: Summary ─────────────────────────────────────
# Used by fast L0 summaries; defaults to DISTILL_* when omitted.
# Benchmark winner: MiniMax 2.7, if exposed through a compatible gateway.
SUMMARY_API_KEY=
SUMMARY_BASE_URL=
# Example: MiniMax-M2.7
SUMMARY_MODEL=

# ─── Legacy Compatibility ──────────────────────────────
# These still work, but are now lower-priority fallbacks.
EXTRACTOR_BASE_URL=
EXTRACTOR_MODEL=

# ─── Storage Configurations ────────────────────────────
MEMORY_DB_PATH=~/.tachi/memory.db
