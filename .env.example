# ─── Embedding & Reranking ─────────────────────────────
# Required for vector embedding and relevance reranking
VOYAGE_API_KEY=your_voyage_api_key_here

# ─── Fact Extraction & Summarization ─────────────────────
# Required for extracting key facts from conversations
# Default uses SiliconFlow, but any OpenAI-compatible endpoint works
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
EXTRACTOR_BASE_URL=https://api.siliconflow.cn/v1
EXTRACTOR_MODEL=Qwen/Qwen3-8B  # or THUDM/glm-4-9b-chat

# ─── Storage Configurations ──────────────────────────────
# Absolute path to the SQLite embedded database file
MEMORY_DB_PATH=~/.tachi/memory.db
